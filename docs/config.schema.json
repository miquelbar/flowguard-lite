{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlowGuard Lite Configuration Schema",
  "type": "object",
  "properties": {
    "admin_password_hash": {
      "type": "string"
    },
    "capture_bpf_filter": {
      "type": "string"
    },
    "capture_interface": {
      "type": "string"
    },
    "capture_promiscuous": {
      "type": "boolean"
    },
    "ddos_threshold_bps": {
      "type": "integer"
    },
    "ddos_threshold_fps": {
      "type": "integer"
    },
    "ddos_threshold_pps": {
      "type": "integer"
    },
    "environment": {
      "type": "string"
    },
    "first_run_completed": {
      "type": "boolean"
    },
    "icmp_flood_threshold_pps": {
      "type": "integer"
    },
    "local_subnets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "log_level": {
      "type": "string"
    },
    "netflow_port": {
      "type": "integer"
    },
    "port": {
      "type": "string"
    },
    "retention_days": {
      "type": "integer"
    },
    "session_secret": {
      "type": "string"
    },
    "sflow_port": {
      "type": "integer"
    },
    "slack_webhook_url": {
      "type": "string"
    },
    "storage_backend": {
      "type": "string",
      "description": "\"sqlite\" or \"duckdb\"",
      "enum": [
        "sqlite",
        "duckdb"
      ]
    },
    "storage_dir": {
      "type": "string"
    },
    "suricata_eve_path": {
      "type": "string"
    },
    "syn_flood_threshold_pps": {
      "type": "integer"
    },
    "telegram_chat_id": {
      "type": "string"
    },
    "telegram_enabled": {
      "type": "boolean"
    },
    "telegram_token": {
      "type": "string"
    },
    "udp_flood_threshold_pps": {
      "type": "integer"
    },
    "unifi_syslog_allowed_ips": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unifi_syslog_enabled": {
      "type": "boolean"
    },
    "unifi_syslog_port": {
      "type": "integer"
    },
    "webhook_format": {
      "type": "string",
      "description": "\"generic\"; legacy \"slack\" migrates to slack_webhook_url",
      "enum": [
        "generic",
        "slack",
        "telegram"
      ]
    },
    "webhook_headers": {},
    "webhook_url": {
      "type": "string"
    }
  },
  "required": [
    "port",
    "netflow_port",
    "sflow_port",
    "capture_interface",
    "capture_bpf_filter",
    "capture_promiscuous",
    "unifi_syslog_enabled",
    "unifi_syslog_port",
    "unifi_syslog_allowed_ips",
    "storage_dir",
    "log_level",
    "environment",
    "local_subnets",
    "ddos_threshold_pps",
    "ddos_threshold_bps",
    "ddos_threshold_fps",
    "syn_flood_threshold_pps",
    "udp_flood_threshold_pps",
    "icmp_flood_threshold_pps",
    "webhook_headers",
    "telegram_enabled",
    "telegram_token",
    "telegram_chat_id",
    "storage_backend",
    "first_run_completed",
    "admin_password_hash",
    "session_secret",
    "retention_days"
  ]
}